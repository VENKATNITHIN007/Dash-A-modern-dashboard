{
  "compilerOptions": {
    /* Target & Libraries */
    "target": "ES2017", // Output JS version (modern enough for async/await support)
    "lib": ["dom", "dom.iterable", "esnext"], // APIs available at runtime (Browser DOM + latest JS)

    /* JavaScript Support */
    "allowJs": true, // Allows importing .js and .jsx files alongside TypeScript
    "skipLibCheck": true, // Skips type checking of declaration files (.d.ts) in node_modules (saves time)

    /* Strictness & Safety */
    "strict": true, // Enables all strict type-checking options (the "gold standard" for safety)
    "noEmit": true, // Next.js handles the build; TypeScript is only used for type checking, not file generation

    /* Module Resolution */
    "esModuleInterop": true, // Simplifies importing CommonJS modules as ES modules
    "module": "esnext", // Sets the module system for the project to the latest standard
    "moduleResolution": "bundler", // Optimizes how modules are found, specifically for tools like Webpack or Vite
    "resolveJsonModule": true, // Allows you to import .json files directly into your code
    "isolatedModules": true, // Ensures every file can be safely transpiled without relying on other files

    /* React / JSX */
    "jsx": "react-jsx", // Support for JSX without needing to manually import React in every file

    /* Build Performance */
    "incremental": true, // Only recompile files that have changed since the last build (much faster)

    /* Framework Specifics */
    "plugins": [
      {
        "name": "next" // Integration for Next.js-specific routing and server component types
      }
    ],

    /* Path Aliasing */
    "paths": {
      "@/*": ["./src/*"] // Allows using "@/" as a shortcut to the "src" directory
    },

    /* Global Types */
    "types": ["vitest/globals"] // Makes Vitest functions (like 'describe' or 'expect') available globally
  },

  /* Inclusion / Exclusion */
  "include": [
    "next-env.d.ts", // Include Next.js environment types
    "**/*.ts", // Include all TypeScript files
    "**/*.tsx", // Include all React TypeScript files
    ".next/types/**/*.ts", // Include types generated by the Next.js App Router
    ".next/dev/types/**/*.ts", // Include dev-specific Next.js types
    "**/*.mts" // Include modern ES module TypeScript files
  ],
  "exclude": ["node_modules"] // Never try to type-check the giant node_modules folder
}